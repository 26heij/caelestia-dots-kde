#!/bin/bash

# Fast-path for polling commands
if [ "$1" = "clients" ] && [ "$2" = "-j" ]; then
    cat /tmp/qs_kwin_windows.json 2>/dev/null || echo "[]"
    exit 0
fi
if [ "$1" = "monitors" ] && [ "$2" = "-j" ]; then
    echo '[{"id":0,"name":"Virtual-1","description":"Virtual-1","make":"","model":"","serial":"","class":"","width":1920,"height":1080,"refreshRate":60.0,"x":0,"y":0,"activeWorkspace":{"id":1,"name":"1"},"specialWorkspace":{"id":0,"name":""},"reserved":[0,0,0,0],"scale":1.0,"transform":0,"focused":true,"dpmsStatus":true,"vrr":false,"solitary":"","active":true}]'
    exit 0
fi
if [ "$1" = "workspaces" ] && [ "$2" = "-j" ]; then
    echo '[{"id":1,"name":"1","monitor":"Virtual-1","windows":1,"hasfullscreen":false,"lastwindow":"","lastwindowtitle":""}]'
    exit 0
fi
if [ "$1" = "activeworkspace" ] && [ "$2" = "-j" ]; then
    echo '{"id":1,"name":"1"}'
    exit 0
fi
if [ "$1" = "layers" ] && [ "$2" = "-j" ]; then
    echo '{}'
    exit 0
fi

# Fallback to python bridge for complex commands (dispatch, globalshortcuts, etc.)
exec /usr/bin/env python3 "$HOME/.local/bin/hyprctl.py" "$@"
